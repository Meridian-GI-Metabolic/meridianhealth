<html xmlns:o="urn:schemas-microsoft-com:office:office"
      xmlns:w="urn:schemas-microsoft-com:office:word"
      xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta charset="UTF-8"/>
<meta name=ProgId content=Word.Document>
<title>Meridian Health — WIP to Launch</title>
<style>
  @page { margin: 25mm 22mm 25mm 28mm; }
  body { font-family: Calibri, Arial, sans-serif; font-size: 11pt; color: #201e11; line-height: 1.6; margin: 0; }

  .cover { page-break-after: always; text-align: center; padding: 80pt 0 60pt; }
  .cover-label { font-size: 9pt; letter-spacing: 3pt; text-transform: uppercase; color: #888; margin-bottom: 18pt; }
  .cover-title { font-family: Georgia, serif; font-size: 30pt; font-weight: normal; color: #201e11; margin: 0 0 10pt; }
  .cover-sub { font-size: 13pt; color: #888; margin-bottom: 40pt; }
  hr.gold { width: 48pt; height: 2pt; background: #c2a55e; border: none; margin: 0 auto 32pt; }
  .cover-meta { font-size: 10pt; color: #888; line-height: 2.4; }

  h1 { font-family: Georgia, serif; font-size: 18pt; font-weight: normal; color: #201e11; margin: 0 0 6pt; page-break-before: always; }
  h1.no-break { page-break-before: avoid; }
  h2 { font-family: Georgia, serif; font-size: 13pt; font-weight: normal; color: #201e11; margin: 24pt 0 4pt; border-bottom: 1pt solid #e8e0d0; padding-bottom: 4pt; }
  hr.rule { width: 30pt; height: 1.5pt; background: #c2a55e; border: none; margin: 0 0 14pt; }

  p { margin: 0 0 8pt; }
  ul, ol { margin: 0 0 10pt 20pt; padding: 0; }
  li { margin-bottom: 5pt; }

  .note  { background: #faf8f4; border-left: 3pt solid #c2a55e; padding: 8pt 12pt; margin: 10pt 0 14pt; font-size: 10pt; color: #555; }
  .warn  { background: #fff8f0; border-left: 3pt solid #e07820; padding: 8pt 12pt; margin: 10pt 0 14pt; font-size: 10pt; color: #555; }
  .done  { background: #f0faf4; border-left: 3pt solid #2a8a4a; padding: 8pt 12pt; margin: 10pt 0 14pt; font-size: 10pt; color: #2a5a36; }
  .block { background: #fff0f0; border-left: 3pt solid #c0392b; padding: 8pt 12pt; margin: 10pt 0 14pt; font-size: 10pt; color: #7a2a2a; }

  .path { font-family: Consolas, monospace; font-size: 9.5pt; background: #f0ede6; padding: 1pt 4pt; border-radius: 2pt; }

  table.t { width: 100%; border-collapse: collapse; margin: 10pt 0 16pt; font-size: 10.5pt; }
  table.t th { background: #201e11; color: #fff; font-size: 9pt; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5pt; padding: 7pt 8pt; text-align: left; }
  table.t td { border-bottom: 1pt solid #e8e0d0; padding: 7pt 8pt; vertical-align: top; }
  table.t tr:nth-child(even) td { background: #faf8f4; }

  .pill { display: inline-block; font-size: 8pt; font-weight: 700; letter-spacing: 0.5pt; text-transform: uppercase; padding: 1pt 7pt; border-radius: 20pt; margin-right: 4pt; }
  .pill-done    { background: #d4edda; color: #1a5c30; }
  .pill-action  { background: #fff3cd; color: #7a4800; }
  .pill-blocked { background: #f8d7da; color: #7a1020; }
  .pill-tbd     { background: #e8e0d0; color: #555; }
  .pill-tech    { background: #dde8f8; color: #1a3a7a; }

  .owner { font-size: 9pt; color: #888; font-style: italic; }

  /* Section headers */
  .section-band { background: #201e11; color: #c2a55e; font-size: 9pt; font-weight: 700; letter-spacing: 2pt; text-transform: uppercase; padding: 5pt 10pt; margin: 20pt 0 0; }

  .check { list-style: none; margin-left: 0; }
  .check li { padding-left: 20pt; position: relative; margin-bottom: 5pt; }
  .check li::before { content: "☐"; position: absolute; left: 0; color: #c2a55e; }
  .check li.done-item::before { content: "✓"; color: #2a8a4a; }
</style>
</head>
<body>

