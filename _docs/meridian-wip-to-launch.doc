    <td class="owner">Practice admin</td>
    <td>No</td>
  </tr>
  <tr>
    <td>5</td>
    <td><strong>Clinical sign-off on Track 10 copy</strong><br>
    <span style="font-size:10pt;color:#555">15 pathway emails (10A–10E) — sign-off form in <span class="path">brevo-email-copy-03-05-and-stage-10.html</span></span></td>
    <td>Clinicians review + sign form</td>
    <td class="owner">Surgeons + physician</td>
    <td>No</td>
  </tr>
